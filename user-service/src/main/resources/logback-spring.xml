<configuration>

    <springProperty scope="context" name="spring.application.name" source="spring.application.name" defaultValue="user-service"/>

    <!-- SAFE local console output -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Loki appender (kept but optional) -->
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>http://loki.monitoring.svc.cluster.local:3100/loki/api/v1/push</url>
        </http>
        <labels>
            app=uber
            service=${spring.application.name}
            level=%level
            env=k8s
        </labels>
        <message class="ch.qos.logback.classic.PatternLayout">
            <pattern>{"timestamp":"%d{ISO8601}","level":"%level","service":"${spring.application.name}","thread":"%thread","logger":"%logger{36}","correlationId":"%X{correlationId:-}","userId":"%X{userId:-}","routingKey":"%X{routingKey:-}","message":"%msg"}</pattern>
        </message>
    </appender>

    <!-- FIX: console is mandatory -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="LOKI"/>
    </root>

</configuration>